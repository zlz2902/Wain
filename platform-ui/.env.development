# 页面标题
VUE_APP_TITLE = 基础平台

# 开发环境配置
ENV = 'development'

# 基础平台/开发环境
#VUE_APP_BASE_API = '/dev-api'
VUE_APP_BASE_API = 'http://localhost:8089'

# 首页 iframe 内嵌「大屏 web」的地址，必须与 web 终端里 Local 地址一致（改完需重启 npm run dev）
VUE_APP_HOME_EMBED_URL = 'http://localhost:9528/'

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES = true
