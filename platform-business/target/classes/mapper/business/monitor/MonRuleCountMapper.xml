<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.horzits.business.mapper.monitor.MonRuleCountMapper">

    <resultMap id="MonRuleCountResult" type="MonRuleCount">
        <id property="countId" column="count_id"/>
        <result property="ruleId" column="rule_id"/>
        <result property="deviceId" column="device_id"/>
        <result property="counts" column="counts"/>
        <result property="lastAlarmTime" column="last_alarm_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectVo">
        select count_id, rule_id, device_id, counts, last_alarm_time, create_time, update_time from mon_rule_count
    </sql>

    <select id="selectMonRuleCountById" resultMap="MonRuleCountResult">
        <include refid="selectVo"/> where count_id = #{countId}
    </select>

    <select id="selectByRuleIdAndDeviceId" resultMap="MonRuleCountResult">
        <include refid="selectVo"/> where rule_id = #{ruleId} and device_id = #{deviceId}
    </select>

    <select id="selectMonRuleCountList" parameterType="MonRuleCount" resultMap="MonRuleCountResult">
        <include refid="selectVo"/>
        <where>
            <if test="ruleId != null">and rule_id = #{ruleId}</if>
            <if test="deviceId != null">and device_id = #{deviceId}</if>
        </where>
        order by count_id desc
    </select>

    <insert id="insertMonRuleCount" parameterType="MonRuleCount" useGeneratedKeys="true" keyProperty="countId">
        insert into mon_rule_count (rule_id, device_id, counts, last_alarm_time, create_time, update_time)
        values (#{ruleId}, #{deviceId}, #{counts}, #{lastAlarmTime}, #{createTime}, #{updateTime})
    </insert>

    <update id="updateMonRuleCount" parameterType="MonRuleCount">
        update mon_rule_count
        <trim prefix="set" suffixOverrides=",">
            <if test="counts != null">counts = #{counts},</if>
            <if test="lastAlarmTime != null">last_alarm_time = #{lastAlarmTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where count_id = #{countId}
    </update>

    <delete id="deleteMonRuleCountById">
        delete from mon_rule_count where count_id = #{countId}
    </delete>

    <delete id="deleteMonRuleCountByIds">
        delete from mon_rule_count where count_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>

    <delete id="deleteMonRuleCountByRuleId">
        delete from mon_rule_count where rule_id = #{ruleId}
    </delete>
</mapper>
