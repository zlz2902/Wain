<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.horzits.business.mapper.monitor.MonDeviceMapper">

    <resultMap id="MonDeviceResult" type="MonDevice">
        <id property="deviceId" column="device_id"/>
        <result property="siteCode" column="site_code"/>
        <result property="deviceCode" column="device_code"/>
        <result property="deviceName" column="device_name"/>
        <result property="brand" column="brand"/>
        <result property="model" column="model"/>
        <result property="runStatus" column="run_status"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectMonDeviceVo">
        select device_id, site_code, device_code, device_name, brand, model, run_status, status, del_flag,
               create_by, create_time, update_by, update_time, remark
        from mon_device
    </sql>

    <select id="selectMonDeviceById" resultMap="MonDeviceResult">
        <include refid="selectMonDeviceVo"/>
        where device_id = #{deviceId} and del_flag = '0'
    </select>

    <select id="selectMonDeviceList" parameterType="MonDevice" resultMap="MonDeviceResult">
        <include refid="selectMonDeviceVo"/>
        <where>
            and del_flag = '0'
            <if test="siteCode != null and siteCode != ''">and site_code = #{siteCode}</if>
            <if test="deviceCode != null and deviceCode != ''">and device_code like concat('%', #{deviceCode}, '%')</if>
            <if test="deviceName != null and deviceName != ''">and device_name like concat('%', #{deviceName}, '%')</if>
            <if test="brand != null and brand != ''">and brand like concat('%', #{brand}, '%')</if>
            <if test="model != null and model != ''">and model like concat('%', #{model}, '%')</if>
            <if test="runStatus != null and runStatus != ''">and run_status = #{runStatus}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''">and create_time &gt;= #{params.beginTime}</if>
            <if test="params.endTime != null and params.endTime != ''">and create_time &lt;= #{params.endTime}</if>
        </where>
        order by device_id desc
    </select>

    <insert id="insertMonDevice" parameterType="MonDevice" useGeneratedKeys="true" keyProperty="deviceId">
        insert into mon_device
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="siteCode != null">site_code,</if>
            <if test="deviceCode != null and deviceCode != ''">device_code,</if>
            <if test="deviceName != null">device_name,</if>
            <if test="brand != null">brand,</if>
            <if test="model != null">model,</if>
            <if test="runStatus != null">run_status,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="siteCode != null">#{siteCode},</if>
            <if test="deviceCode != null and deviceCode != ''">#{deviceCode},</if>
            <if test="deviceName != null">#{deviceName},</if>
            <if test="brand != null">#{brand},</if>
            <if test="model != null">#{model},</if>
            <if test="runStatus != null">#{runStatus},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateMonDevice" parameterType="MonDevice">
        update mon_device
        <trim prefix="set" suffixOverrides=",">
            <if test="siteCode != null">site_code = #{siteCode},</if>
            <if test="deviceCode != null and deviceCode != ''">device_code = #{deviceCode},</if>
            <if test="deviceName != null">device_name = #{deviceName},</if>
            <if test="brand != null">brand = #{brand},</if>
            <if test="model != null">model = #{model},</if>
            <if test="runStatus != null">run_status = #{runStatus},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where device_id = #{deviceId} and del_flag = '0'
    </update>

    <update id="deleteMonDeviceById">
        update mon_device set del_flag = '2' where device_id = #{deviceId}
    </update>

    <update id="deleteMonDeviceByIds">
        update mon_device set del_flag = '2' where device_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
