<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.horzits.business.mapper.monitor.MonDeviceMapper">

    <resultMap id="MonDeviceResult" type="MonDevice">
        <id property="deviceId" column="id"/>
        <result property="deviceNo" column="device_no"/>
        <result property="gatewayno" column="gatewayno"/>
        <result property="deviceName" column="device_name"/>
        <result property="deviceType" column="device_type"/>
        <result property="terminalno" column="terminalno"/>
        <result property="stationId" column="station_id"/>
        <result property="owner" column="owner"/>
        <result property="installDate" column="install_date"/>
        <result property="isEnabled" column="is_enabled"/>
        <result property="createTime" column="created_at"/>
        <result property="updateTime" column="updated_at"/>
    </resultMap>

    <sql id="selectMonDeviceVo">
        select id, device_no, gatewayno, device_name, device_type, terminalno, station_id, owner,
               install_date, is_enabled, created_at, updated_at
        from device_info
    </sql>

    <select id="selectStationIdByDeviceNo" resultType="long">
        select station_id from device_info where device_no = #{deviceNo} limit 1
    </select>

    <select id="selectMonDeviceById" resultMap="MonDeviceResult">
        <include refid="selectMonDeviceVo"/>
        where id = #{deviceId} and is_enabled = 1
    </select>

    <select id="selectMonDeviceList" parameterType="MonDevice" resultMap="MonDeviceResult">
        <include refid="selectMonDeviceVo"/>
        <where>
            and is_enabled = 1
            <if test="stationId != null">and station_id = #{stationId}</if>
            <if test="deviceNo != null and deviceNo != ''">and device_no like concat('%', #{deviceNo}, '%')</if>
            <if test="gatewayno != null and gatewayno != ''">and gatewayno like concat('%', #{gatewayno}, '%')</if>
            <if test="deviceName != null and deviceName != ''">and device_name like concat('%', #{deviceName}, '%')</if>
            <if test="deviceType != null and deviceType != ''">and device_type like concat('%', #{deviceType}, '%')</if>
            <if test="params.beginTime != null and params.beginTime != ''">and created_at &gt;= #{params.beginTime}</if>
            <if test="params.endTime != null and params.endTime != ''">and created_at &lt;= #{params.endTime}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertMonDevice" parameterType="MonDevice" useGeneratedKeys="true" keyProperty="deviceId">
        insert into device_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceNo != null and deviceNo != ''">device_no,</if>
            <if test="gatewayno != null">gatewayno,</if>
            <if test="deviceName != null">device_name,</if>
            <if test="deviceType != null">device_type,</if>
            <if test="terminalno != null">terminalno,</if>
            <if test="stationId != null">station_id,</if>
            <if test="owner != null">owner,</if>
            <if test="installDate != null">install_date,</if>
            <if test="isEnabled != null">is_enabled,</if>
            created_at,
            updated_at,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceNo != null and deviceNo != ''">#{deviceNo},</if>
            <if test="gatewayno != null">#{gatewayno},</if>
            <if test="deviceName != null">#{deviceName},</if>
            <if test="deviceType != null">#{deviceType},</if>
            <if test="terminalno != null">#{terminalno},</if>
            <if test="stationId != null">#{stationId},</if>
            <if test="owner != null">#{owner},</if>
            <if test="installDate != null">#{installDate},</if>
            <if test="isEnabled != null">#{isEnabled},</if>
            #{createTime},
            #{updateTime},
        </trim>
    </insert>

    <update id="updateMonDevice" parameterType="MonDevice">
        update device_info
        <trim prefix="set" suffixOverrides=",">
            <if test="deviceNo != null and deviceNo != ''">device_no = #{deviceNo},</if>
            <if test="gatewayno != null">gatewayno = #{gatewayno},</if>
            <if test="deviceName != null">device_name = #{deviceName},</if>
            <if test="deviceType != null">device_type = #{deviceType},</if>
            <if test="terminalno != null">terminalno = #{terminalno},</if>
            <if test="stationId != null">station_id = #{stationId},</if>
            <if test="owner != null">owner = #{owner},</if>
            <if test="installDate != null">install_date = #{installDate},</if>
            <if test="isEnabled != null">is_enabled = #{isEnabled},</if>
            updated_at = #{updateTime},
        </trim>
        where id = #{deviceId} and is_enabled = 1
    </update>

    <update id="deleteMonDeviceById">
        update device_info set is_enabled = 0, updated_at = now() where id = #{deviceId}
    </update>

    <update id="deleteMonDeviceByIds">
        update device_info set is_enabled = 0, updated_at = now() where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
